package server

import (
	"context"
	"log/slog"
	"net/http"

	"github.com/assanoff/skit/health"
	"github.com/assanoff/skit/httplog"
	"github.com/assanoff/skit/metrics"
	"github.com/assanoff/skit/middleware"
	"github.com/assanoff/skit/rest"
	"github.com/assanoff/skit/rest/mid"
	"github.com/assanoff/skit/rest/router"

	"{{.Module}}/internal/app/deps"
)

// buildRouter constructs the HTTP handler: it builds the router shell (the typed
// handler middleware) and hands it to Install, which describes every route in
// one place. Global middleware (trace + access log) wraps every route; the
// request-scoped middleware (metrics, timeout, body limit) is applied only to
// business routes via a sub-group inside Install.
func buildRouter(ctx context.Context, d *deps.Deps, m *metrics.Metrics) http.Handler {
	log := d.Logger
	tracer := d.Tracer(ctx)

	// App middleware applied to every typed handler (mid.Chain, in order):
	// LocalizeErrors -> MaskInternal (hides 5xx detail in production) -> Errors
	// (records 5xx on the span + logs) -> Panics (turns a panic into a clean
	// Internal error). Localization is off until you wire i18n (Translator/Lang).
	appMids := mid.Chain(mid.Config{
		Logger:       log,
		MaskInternal: d.Opts.Env == "production",
	})
	r := router.New(appMids...)

	// Global middleware — safe for every route. Access logging (httplog) also
	// recovers panics; TraceRequest runs first so trace_id is present.
	r.Use(
		middleware.TraceRequest(tracer),
		httplog.Middleware(log.Named("access"), &httplog.Options{
			Level:         slog.LevelInfo,
			Schema:        httplog.SchemaOTEL.Concise(true),
			RecoverPanics: true,
		}),
	)

	Install(ctx, r, d, m)
	return r
}

// Install describes every HTTP route on r. It is the single place that composes
// the application's transport: technical probes plus the request-scoped business
// sub-group. Feature handlers register via their Routes(handle) method using the
// handle seam, so they never depend on the router type.
func Install(ctx context.Context, r *router.Router, d *deps.Deps, m *metrics.Metrics) {
	r.HandleFunc("GET /healthz", health.Liveness())
	r.Handle("GET /readyz", readiness(d))

	// Business endpoints carry the request-scoped middleware (HTTP metrics, per
	// request timeout, body-size limit). handle is the seam handed to features.
	api := r.With(
		m.Middleware(),
		middleware.Timeout(d.Opts.HTTP.RequestTimeout),
		middleware.SizeLimit(d.Opts.HTTP.BodySizeLimit),
	)
	handle := api.HandleApp

	// Sample route — replace with your domain handlers, e.g.:
	//   d.WalletHandler(ctx).Routes(handle)
	handle("GET /hello", hello)
	_ = ctx
}

func hello(_ context.Context, _ *http.Request) rest.ResponseEncoder {
	return rest.JSON(map[string]string{"msg": "hello"})
}
